{
  "expo": {
    "name": "CoFund",
    "slug": "cofund",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "cofund",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#0e3d6e"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "africa.cofund.app"
    },
    "android": {
      "package": "africa.cofund.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0e3d6e"
      },
      "permissions": []
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#1a5e9a",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "81a6ce31-26d5-4a99-be1c-17700038ec9b"
      }
    },
    "owner": "aremartins"
  }
}
