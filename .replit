modules = ["nodejs-20"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Tunnel"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "REACT_NATIVE_PACKAGER_HOSTNAME=cofund-dev.loca.lt npx expo start --port 8080 --dev-client"
waitForPort = 8080

[[workflows.workflow]]
name = "Tunnel"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx lt --port 8080 --subdomain cofund-dev"

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 8080
externalPort = 80

[nix]
channel = "stable-25_05"
